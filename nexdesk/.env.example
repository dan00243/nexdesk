# NexDesk — Variables d'environnement
# Copier vers .env et remplir les valeurs

# Base de données
POSTGRES_USER=nexdesk
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=nexdesk

# Sécurité — générer avec: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_128_CHAR_HEX_STRING

# Signaling
SIGNALING_SECRET=CHANGE_ME_64_CHAR_HEX

# Debug (false en production)
DEBUG=false
